# ============================================
# AutoX — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to version control

# ============================================
# LLM API Keys (add the ones you have)
# ============================================
GEMINI_API_KEY=
CLAUDE_API_KEY=

# Default model: "gemini-flash" or "claude-sonnet"
DEFAULT_LLM_MODEL=gemini-flash

# ============================================
# X/Twitter API Keys — Per Account
# ============================================
# Each account has its own set of API credentials.
# Replace <N> with account number (1-7) and fill in.

# Account 1
X_ACCOUNT_1_NAME=
X_ACCOUNT_1_HANDLE=
X_ACCOUNT_1_API_KEY=
X_ACCOUNT_1_API_SECRET=
X_ACCOUNT_1_ACCESS_TOKEN=
X_ACCOUNT_1_ACCESS_TOKEN_SECRET=
X_ACCOUNT_1_BEARER_TOKEN=

# Account 2
X_ACCOUNT_2_NAME=
X_ACCOUNT_2_HANDLE=
X_ACCOUNT_2_API_KEY=
X_ACCOUNT_2_API_SECRET=
X_ACCOUNT_2_ACCESS_TOKEN=
X_ACCOUNT_2_ACCESS_TOKEN_SECRET=
X_ACCOUNT_2_BEARER_TOKEN=

# Account 3
X_ACCOUNT_3_NAME=
X_ACCOUNT_3_HANDLE=
X_ACCOUNT_3_API_KEY=
X_ACCOUNT_3_API_SECRET=
X_ACCOUNT_3_ACCESS_TOKEN=
X_ACCOUNT_3_ACCESS_TOKEN_SECRET=
X_ACCOUNT_3_BEARER_TOKEN=

# Account 4
X_ACCOUNT_4_NAME=
X_ACCOUNT_4_HANDLE=
X_ACCOUNT_4_API_KEY=
X_ACCOUNT_4_API_SECRET=
X_ACCOUNT_4_ACCESS_TOKEN=
X_ACCOUNT_4_ACCESS_TOKEN_SECRET=
X_ACCOUNT_4_BEARER_TOKEN=

# Account 5
X_ACCOUNT_5_NAME=
X_ACCOUNT_5_HANDLE=
X_ACCOUNT_5_API_KEY=
X_ACCOUNT_5_API_SECRET=
X_ACCOUNT_5_ACCESS_TOKEN=
X_ACCOUNT_5_ACCESS_TOKEN_SECRET=
X_ACCOUNT_5_BEARER_TOKEN=

# Account 6
X_ACCOUNT_6_NAME=
X_ACCOUNT_6_HANDLE=
X_ACCOUNT_6_API_KEY=
X_ACCOUNT_6_API_SECRET=
X_ACCOUNT_6_ACCESS_TOKEN=
X_ACCOUNT_6_ACCESS_TOKEN_SECRET=
X_ACCOUNT_6_BEARER_TOKEN=

# Account 7
X_ACCOUNT_7_NAME=
X_ACCOUNT_7_HANDLE=
X_ACCOUNT_7_API_KEY=
X_ACCOUNT_7_API_SECRET=
X_ACCOUNT_7_ACCESS_TOKEN=
X_ACCOUNT_7_ACCESS_TOKEN_SECRET=
X_ACCOUNT_7_BEARER_TOKEN=

# ============================================
# Typefully API (optional — per account)
# ============================================
# If using Typefully for scheduling/publishing
TYPEFULLY_ACCOUNT_1_API_KEY=
TYPEFULLY_ACCOUNT_2_API_KEY=
TYPEFULLY_ACCOUNT_3_API_KEY=
TYPEFULLY_ACCOUNT_4_API_KEY=
TYPEFULLY_ACCOUNT_5_API_KEY=
TYPEFULLY_ACCOUNT_6_API_KEY=
TYPEFULLY_ACCOUNT_7_API_KEY=

# ============================================
# Database
# ============================================
# Postgres connection string (e.g. Supabase pooler URL).
# NEVER commit the real URL — set it in Vercel/host env vars only.
# After setting it, apply the schema once with: npx prisma migrate deploy
DATABASE_URL=

# ============================================
# Scheduling & Publishing
# ============================================
# Secret required to call /api/publish/cron.
# Vercel Cron sends it automatically as "Authorization: Bearer <CRON_SECRET>"
# when this env var is set. External schedulers must send the same header.
CRON_SECRET=

# IANA timezone that scheduled post times (HH:MM) are interpreted in.
# Defaults to UTC when unset. Example: Asia/Kolkata
SCHEDULE_TIMEZONE=Asia/Kolkata

# ============================================
# Dashboard access control
# ============================================
# When both are set, the whole app (pages + APIs, except the cron endpoint)
# is protected with HTTP Basic Auth. Leave empty to disable (local dev).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
